@inproceedings{quweider_deep_2025,
	title = {A {Deep} {Dive} {Into} {FAT}-32 {Windows} {File} {System}: {A} {Digital} {Forensics} {Perspective}},
	shorttitle = {A {Deep} {Dive} {Into} {FAT}-32 {Windows} {File} {System}},
	url = {https://ieeexplore.ieee.org/abstract/document/11472363},
	doi = {10.1109/ICECET63943.2025.11472363},
	abstract = {For digital forensics analysts, the file system of a digital computing/storage device is an excellent source of relevant information that can aid in an investigation or analysis of a case at hand. Therefore, a solid understanding of the file system details and how to identify, extract, analyze, and present the data on a given device becomes crucial to a successful inquiry or investigation. In this paper, we present a detailed overview of the Windows operating system's FAT-32 file system with an emphasis on its importance from a digital forensics perspective. We review the overall technical mechanisms and processes with context and background by which files are organized including data (content) and metadata/attributes, identify fields that are unique to the file system, point out places where data can be hidden or masked, and how data recovery and carving techniques work with the file system. We also conduct a detailed walk-through of each filesystem component using low-level tools and verify the results with current acquisition, recovery, and carving of data tools.},
	urldate = {2026-04-23},
	booktitle = {2025 5th {International} {Conference} on {Electrical}, {Computer} and {Energy} {Technologies} ({ICECET})},
	author = {Quweider, MK},
	month = jul,
	year = {2025},
	keywords = {Cellular phones, Communication systems, Data Carving, Data Recovery, FAT-32, File System, HTTP, Internet, Internet of Things, Media Access Control, Protocols, Storage Media, TV, Video equipment, Videos, Windows},
	pages = {1--11},
	file = {Full Text PDF:C\:\\Users\\luker\\Zotero\\storage\\Y8HDFTLQ\\Quweider - 2025 - A Deep Dive Into FAT-32 Windows File System A Digital Forensics Perspective.pdf:application/pdf},
}
